import torch
from torch import nn

# prepare input data
X1 = torch.tensor([10], dtype = torch.float32)
Y1 = torch.tensor([50], dtype = torch.float32)

X2 = torch.tensor([37.78], dtype = torch.float32)
Y2 = torch.tensor([100], dtype = torch.float32)

# Prepare for training
model = nn.Linear(in_features=1, out_features=1)
loss_fn = nn.MSELoss()

# print(loss_fn(
#     torch.tensor([5.5]),
#     torch.tensor([50.0]),
# ))

# for i in model.parameters():
#     print(i)

optimizer = torch.optim.SGD(model.parameters(), lr=0.0001)
print(f"Initial Weights before Training Pass")
print(f"Model bias:{model.bias}")
print(f"Model weight:{model.weight}")

for i in range(1, 100000):

    # Training Pass
    # Forward pass, Loss calculation, Backward Pass and Parameter Update

    # Step 1: Zero the gradients
    optimizer.zero_grad()

    # Step 2: Forward Pass
    y_pred = model(X1)

    # Step 3: Loss Calculation
    loss = loss_fn(y_pred, Y1)
    # print(f"loss: {loss}")

    # Step 4: Backward Pass
    loss.backward()

    # Step 5: Update the Parameters
    optimizer.step()

    # Training Pass
    # Forward pass, Loss calculation, Backward Pass and Parameter Update

    # Step 1: Zero the gradients
    optimizer.zero_grad()

    # Step 2: Forward Pass
    y_pred = model(X2)

    # Step 3: Loss Calculation
    loss = loss_fn(y_pred, Y2)
    # print(f"loss: {loss}")

    # Step 4: Backward Pass
    loss.backward()

    # Step 5: Update the Parameters
    optimizer.step()


    if i % 1000 == 0:
        print(f"Updated Weights after Training Pass at {i}")
        print(f"Model bias:{model.bias}")
        print(f"Model weight:{model.weight}")
        print()

    

